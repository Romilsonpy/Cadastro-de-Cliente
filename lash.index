<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Stúdio Emily Lash Designer | Agendamento + Manutenção</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', 'Segoe UI', system-ui, 'Inter', sans-serif;
        }

        body {
            background: linear-gradient(145deg, #0a0a0a 0%, #1a1a1a 100%);
            min-height: 100vh;
            padding: 2rem 1.5rem;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        /* Container principal */
        .app-container {
            max-width: 1400px;
            width: 100%;
            background: #000000dd;
            backdrop-filter: blur(2px);
            border-radius: 2.5rem;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.8), 0 0 0 2px #f5b700, 0 0 0 6px #1e1e1e;
            overflow: hidden;
        }

        /* Cabeçalho */
        .hero {
            background: radial-gradient(circle at 20% 30%, #f5b700, #e09d00);
            padding: 1.5rem 2rem;
            text-align: center;
            border-bottom: 3px solid #ffd966;
        }

        .hero h1 {
            font-size: 2.5rem;
            font-weight: 800;
            color: #0f0f0f;
            text-shadow: 0 2px 5px rgba(255,235,130,0.6);
        }

        .hero h1 span {
            background: black;
            color: #f5b700;
            padding: 0 0.5rem;
            border-radius: 40px;
            display: inline-block;
            font-size: 1.8rem;
        }

        .hero p {
            font-size: 1rem;
            font-weight: 600;
            color: #1e1e1e;
            background: #fff0b5;
            display: inline-block;
            padding: 0.2rem 1.2rem;
            border-radius: 40px;
            margin-top: 0.5rem;
        }

        /* Abas */
        .tabs {
            display: flex;
            background: #0a0a0a;
            border-bottom: 2px solid #f5b70055;
            padding: 0 1rem;
            gap: 0.5rem;
        }

        .tab-btn {
            background: transparent;
            border: none;
            padding: 1rem 2rem;
            font-size: 1rem;
            font-weight: 700;
            color: #ddd;
            cursor: pointer;
            transition: 0.2s;
            border-radius: 1rem 1rem 0 0;
            position: relative;
        }

        .tab-btn:hover {
            color: #f5b700;
            background: #1a1a1a;
        }

        .tab-btn.active {
            color: #f5b700;
            background: #121212;
            border-bottom: 3px solid #f5b700;
        }

        /* Conteúdo das abas */
        .tab-content {
            display: none;
            padding: 2rem;
            background: #0b0b0b;
            animation: fadeIn 0.2s ease;
        }

        .tab-content.active {
            display: block;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(5px);}
            to { opacity: 1; transform: translateY(0);}
        }

        /* Layout do agendamento (igual ao anterior) */
        .dashboard {
            display: flex;
            flex-wrap: wrap;
            gap: 2rem;
        }

        .form-section {
            flex: 1.2;
            min-width: 280px;
            background: #121212;
            border-radius: 1.8rem;
            padding: 1.8rem;
            border: 1px solid #f5b70055;
        }

        .form-section h2 {
            color: #f5b700;
            font-size: 1.8rem;
            border-left: 6px solid #f5b700;
            padding-left: 1rem;
            margin-bottom: 1.5rem;
        }

        .form-group {
            margin-bottom: 1.2rem;
        }

        label {
            display: block;
            font-weight: 600;
            margin-bottom: 0.5rem;
            color: #ffdd88;
        }

        input, select, textarea {
            width: 100%;
            padding: 0.9rem 1rem;
            background: #1f1f1f;
            border: 1.5px solid #333;
            border-radius: 1rem;
            font-size: 1rem;
            color: #f0f0f0;
            transition: all 0.2s;
            outline: none;
        }

        input:focus, select:focus, textarea:focus {
            border-color: #f5b700;
            box-shadow: 0 0 0 3px rgba(245, 183, 0, 0.3);
            background: #262626;
        }

        textarea {
            resize: vertical;
            min-height: 80px;
        }

        .btn-agendar {
            width: 100%;
            background: #f5b700;
            color: #000;
            font-weight: 800;
            font-size: 1.2rem;
            padding: 1rem;
            border: none;
            border-radius: 2rem;
            cursor: pointer;
            transition: 0.2s;
            margin-top: 1rem;
            box-shadow: 0 5px 0 #b47c00;
        }

        .btn-agendar:hover {
            background: #ffcd42;
            transform: translateY(-2px);
            box-shadow: 0 7px 0 #b47c00;
        }

        .list-section {
            flex: 2;
            min-width: 320px;
            background: #121212;
            border-radius: 1.8rem;
            padding: 1.8rem;
            border: 1px solid #f5b70055;
        }

        .list-header {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            flex-wrap: wrap;
            margin-bottom: 1.5rem;
        }

        .list-header h2 {
            color: #f5b700;
            font-size: 1.8rem;
            border-left: 6px solid #f5b700;
            padding-left: 1rem;
        }

        .badge-count {
            background: #f5b700;
            color: #000;
            font-weight: bold;
            padding: 0.3rem 0.9rem;
            border-radius: 40px;
            font-size: 0.9rem;
        }

        .filtro {
            margin-bottom: 1.5rem;
            display: flex;
            gap: 0.7rem;
            flex-wrap: wrap;
            align-items: center;
        }

        .filtro input {
            flex: 2;
            min-width: 150px;
        }

        .btn-limpar {
            background: #2c2c2c;
            border: 1px solid #f5b700;
            color: #f5b700;
            padding: 0.6rem 1.2rem;
            border-radius: 2rem;
            font-weight: bold;
            cursor: pointer;
            transition: 0.2s;
        }

        .btn-limpar:hover {
            background: #f5b700;
            color: #000;
        }

        .cards-container {
            max-height: 500px;
            overflow-y: auto;
            padding-right: 5px;
        }

        .card {
            background: #1c1c1c;
            border-radius: 1.2rem;
            margin-bottom: 1rem;
            padding: 1rem 1.2rem;
            border-left: 8px solid #f5b700;
            transition: 0.1s;
        }

        .card:hover {
            background: #242424;
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 0.5rem;
            margin-bottom: 0.5rem;
            align-items: baseline;
        }

        .nome-cliente {
            font-size: 1.3rem;
            font-weight: 700;
            color: #ffde9e;
        }

        .data-hora {
            background: #2a2a2a;
            padding: 0.2rem 0.7rem;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 600;
            color: #f5b700;
        }

        .servico {
            font-weight: 600;
            color: #ccc;
            margin: 0.4rem 0;
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .servico span {
            background: #2c2c2c;
            padding: 0.2rem 0.8rem;
            border-radius: 20px;
            font-size: 0.8rem;
            color: #f5e1a0;
        }

        .observacao {
            font-size: 0.85rem;
            color: #b0b0b0;
            margin-top: 0.3rem;
            font-style: italic;
        }

        .btn-remover {
            background: none;
            border: none;
            color: #ff9966;
            font-weight: bold;
            cursor: pointer;
            font-size: 0.85rem;
            margin-top: 0.5rem;
            text-align: right;
            display: inline-block;
            background: #2a2a2a;
            padding: 0.2rem 0.8rem;
            border-radius: 20px;
        }

        .btn-remover:hover {
            background: #f5b700;
            color: #000;
        }

        /* Estilos da aba manutenção */
        .manutencao-container {
            display: flex;
            flex-wrap: wrap;
            gap: 2rem;
            justify-content: center;
        }

        .card-manutencao {
            background: #121212;
            border: 1px solid #f5b70055;
            border-radius: 1.8rem;
            padding: 2rem;
            flex: 1;
            min-width: 260px;
            text-align: center;
            transition: 0.2s;
        }

        .card-manutencao h3 {
            color: #f5b700;
            font-size: 1.8rem;
            margin-bottom: 1rem;
        }

        .card-manutencao p {
            color: #ccc;
            margin-bottom: 1.5rem;
            font-size: 0.9rem;
        }

        .btn-manutencao {
            background: #f5b700;
            color: #000;
            border: none;
            padding: 0.8rem 1.8rem;
            font-weight: bold;
            border-radius: 2rem;
            cursor: pointer;
            font-size: 1rem;
            transition: 0.2s;
            margin: 0.3rem;
            box-shadow: 0 2px 5px rgba(0,0,0,0.3);
        }

        .btn-manutencao:hover {
            background: #ffcd42;
            transform: scale(1.02);
        }

        .btn-perigo {
            background: #2c2c2c;
            color: #ffaa66;
            border: 1px solid #f5b700;
        }

        .btn-perigo:hover {
            background: #f5b700;
            color: #000;
        }

        .info-backup {
            background: #1f1f1f;
            border-radius: 1rem;
            padding: 0.8rem;
            margin-top: 1rem;
            font-size: 0.8rem;
            color: #f5b700aa;
            word-break: break-all;
        }

        footer {
            background: #050505;
            padding: 1rem;
            text-align: center;
            border-top: 1px solid #f5b70033;
            color: #f5b700aa;
            font-size: 0.8rem;
        }

        @media (max-width: 780px) {
            body { padding: 1rem; }
            .hero h1 { font-size: 1.8rem; }
            .tab-btn { padding: 0.7rem 1rem; font-size: 0.9rem; }
            .dashboard { padding: 1rem; }
            .tab-content { padding: 1rem; }
        }

        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #1f1f1f; border-radius: 10px; }
        ::-webkit-scrollbar-thumb { background: #f5b700; border-radius: 10px; }
    </style>
</head>
<body>
<div class="app-container">
    <div class="hero">
        <h1>👁️ Stúdio <span>Emily Lash Designer</span></h1>
        <p>✨ Agendamento profissional • Backup seguro ✨</p>
    </div>

    <!-- Sistema de Abas -->
    <div class="tabs">
        <button class="tab-btn active" data-tab="agenda">📅 Agendamentos</button>
        <button class="tab-btn" data-tab="manutencao">⚙️ Manutenção • Backup</button>
    </div>

    <!-- ABA AGENDAMENTOS -->
    <div id="tab-agenda" class="tab-content active">
        <div class="dashboard">
            <!-- Formulário -->
            <div class="form-section">
                <h2>✍️ Novo Agendamento</h2>
                <form id="formAgendamento">
                    <div class="form-group">
                        <label>👤 Nome completo *</label>
                        <input type="text" id="nome" placeholder="Ex: Emily Souza" required>
                    </div>
                    <div class="form-group">
                        <label>📱 WhatsApp / Telefone *</label>
                        <input type="tel" id="telefone" placeholder="(99) 99999-9999" required>
                    </div>
                    <div class="form-group">
                        <label>📅 Data *</label>
                        <input type="date" id="data" required>
                    </div>
                    <div class="form-group">
                        <label>⏰ Horário *</label>
                        <select id="horario" required>
                            <option value="">Selecione um horário</option>
                            <option>09:00</option><option>09:30</option><option>10:00</option><option>10:30</option>
                            <option>11:00</option><option>11:30</option><option>12:00</option><option>13:00</option>
                            <option>13:30</option><option>14:00</option><option>14:30</option><option>15:00</option>
                            <option>15:30</option><option>16:00</option><option>16:30</option><option>17:00</option>
                            <option>17:30</option><option>18:00</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>💅 Tipo de Serviço *</label>
                        <select id="servico" required>
                            <option value="">Escolha o serviço</option>
                            <option>Volume Brasileiro</option><option>Volume Egípcio</option>
                            <option>Fio a Fio Clássico</option><option>Lash Lifting + Tintura</option>
                            <option>Manutenção de Cílios</option><option>Remoção Profissional</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>📝 Observações</label>
                        <textarea id="obs" placeholder="Alguma alergia, preferência ou recado..."></textarea>
                    </div>
                    <button type="submit" class="btn-agendar">💛 AGENDAR HORÁRIO 💛</button>
                </form>
            </div>

            <!-- Listagem -->
            <div class="list-section">
                <div class="list-header">
                    <h2>📋 Próximos Atendimentos</h2>
                    <div class="badge-count" id="contadorAgendamentos">0 agendamentos</div>
                </div>
                <div class="filtro">
                    <input type="text" id="filtroNome" placeholder="🔍 Filtrar por nome, serviço ou telefone...">
                    <button id="btnLimparFiltro" class="btn-limpar">Limpar filtro</button>
                </div>
                <div id="listaCards" class="cards-container">
                    <div class="sem-agendamentos">✨ Carregando agendamentos... ✨</div>
                </div>
            </div>
        </div>
    </div>

    <!-- ABA MANUTENÇÃO / BACKUP -->
    <div id="tab-manutencao" class="tab-content">
        <div class="manutencao-container">
            <div class="card-manutencao">
                <h3>💾 Backup</h3>
                <p>Exportar todos os agendamentos atuais em um arquivo JSON.<br>Ideal para guardar uma cópia segura.</p>
                <button id="btnFazerBackup" class="btn-manutencao">📀 Baixar Backup (JSON)</button>
                <div class="info-backup">✔️ Os dados são salvos localmente no seu navegador. O backup exporta todos os agendamentos.</div>
            </div>
            <div class="card-manutencao">
                <h3>🔄 Restaurar Backup</h3>
                <p>Importe um arquivo JSON previamente exportado.<br>Substitui TODOS os agendamentos atuais.</p>
                <input type="file" id="restoreFileInput" accept=".json" style="display: none;">
                <button id="btnSelecionarRestore" class="btn-manutencao">📂 Selecionar arquivo</button>
                <button id="btnRestaurar" class="btn-manutencao btn-perigo" style="margin-top: 10px;">⚠️ RESTAURAR BACKUP</button>
                <div class="info-backup" id="infoRestoreMsg">Nenhum arquivo selecionado.</div>
            </div>
            <div class="card-manutencao">
                <h3>🧹 Limpeza Total</h3>
                <p>Remove TODOS os agendamentos permanentemente.<br>Use com cuidado!</p>
                <button id="btnLimparTudo" class="btn-manutencao btn-perigo">🗑️ Apagar todos os dados</button>
                <div class="info-backup">Essa ação não pode ser desfeita. Faça backup antes.</div>
            </div>
        </div>
    </div>

    <footer>
        💛 Stúdio Emily Lash Designer • Beleza que transforma olhares • Agendamentos com responsabilidade + Backup seguro 💛
    </footer>
</div>

<script>
    // ---------- CONFIGURAÇÕES GLOBAIS ----------
    const STORAGE_KEY = "studio_emily_agendamentos";
    let agendamentos = [];

    // Elementos da aba agendamento
    const form = document.getElementById("formAgendamento");
    const nomeInput = document.getElementById("nome");
    const telefoneInput = document.getElementById("telefone");
    const dataInput = document.getElementById("data");
    const horarioSelect = document.getElementById("horario");
    const servicoSelect = document.getElementById("servico");
    const obsTextarea = document.getElementById("obs");
    const listaContainer = document.getElementById("listaCards");
    const contadorSpan = document.getElementById("contadorAgendamentos");
    const filtroInput = document.getElementById("filtroNome");
    const btnLimparFiltro = document.getElementById("btnLimparFiltro");

    // Elementos da aba manutenção
    const btnBackup = document.getElementById("btnFazerBackup");
    const btnSelecionarRestore = document.getElementById("btnSelecionarRestore");
    const btnRestaurar = document.getElementById("btnRestaurar");
    const restoreFileInput = document.getElementById("restoreFileInput");
    const infoRestoreMsg = document.getElementById("infoRestoreMsg");
    const btnLimparTudo = document.getElementById("btnLimparTudo");
    let arquivoSelecionado = null;

    // Abas
    const tabBtns = document.querySelectorAll(".tab-btn");
    const tabContents = {
        agenda: document.getElementById("tab-agenda"),
        manutencao: document.getElementById("tab-manutencao")
    };

    // Utilitários
    function formatarDataLegivel(dataStr) {
        if (!dataStr) return "Data inválida";
        const partes = dataStr.split("-");
        if (partes.length !== 3) return dataStr;
        return `${partes[2]}/${partes[1]}/${partes[0]}`;
    }

    function escapeHtml(str) {
        if (!str) return "";
        return str.replace(/[&<>]/g, function(m) {
            if (m === '&') return '&amp;';
            if (m === '<') return '&lt;';
            if (m === '>') return '&gt;';
            return m;
        });
    }

    function salvarAgendamentos() {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(agendamentos));
    }

    function ordenarAgendamentos() {
        agendamentos.sort((a,b) => {
            if (a.data === b.data) return a.horario.localeCompare(b.horario);
            return a.data.localeCompare(b.data);
        });
    }

    // Carregar dados iniciais
    function carregarAgendamentos() {
        const stored = localStorage.getItem(STORAGE_KEY);
        if (stored) {
            try {
                agendamentos = JSON.parse(stored);
                if (!Array.isArray(agendamentos)) agendamentos = [];
                agendamentos = agendamentos.filter(ag => ag && ag.id).map(ag => ({ ...ag }));
            } catch(e) { agendamentos = []; }
        } 
        // Se não tiver dados ou estiver vazio, colocar exemplos apenas se vazio
        if (!agendamentos.length) {
            const hoje = new Date();
            const amanha = new Date(hoje);
            amanha.setDate(hoje.getDate() + 1);
            const dataHojeStr = hoje.toISOString().slice(0,10);
            const dataAmanhaStr = amanha.toISOString().slice(0,10);
            agendamentos = [
                { id: 1001, nome: "Fernanda Lima", telefone: "(11) 98765-4321", data: dataHojeStr, horario: "14:00", servico: "Volume Brasileiro", obs: "Primeira vez, quer volume mega efeito" },
                { id: 1002, nome: "Carolina Mendes", telefone: "(21) 99888-7766", data: dataAmanhaStr, horario: "10:30", servico: "Lash Lifting + Tintura", obs: "Cílios sensíveis" },
                { id: 1003, nome: "Rafaela Dias", telefone: "(31) 97777-5555", data: dataHojeStr, horario: "16:00", servico: "Fio a Fio Clássico", obs: "Natural" }
            ];
            salvarAgendamentos();
        }
        ordenarAgendamentos();
        renderizarAgendamentos();
    }

    function renderizarAgendamentos() {
        let filtroTexto = filtroInput.value.trim().toLowerCase();
        let listaFiltrada = agendamentos;
        if (filtroTexto !== "") {
            listaFiltrada = agendamentos.filter(ag =>
                ag.nome.toLowerCase().includes(filtroTexto) ||
                ag.servico.toLowerCase().includes(filtroTexto) ||
                ag.telefone.includes(filtroTexto)
            );
        }
        const total = agendamentos.length;
        const filtradosCount = listaFiltrada.length;
        if (filtroTexto === "") contadorSpan.innerText = `${total} ${total === 1 ? 'agendamento' : 'agendamentos'}`;
        else contadorSpan.innerText = `${filtradosCount} de ${total} (filtrado)`;

        if (listaFiltrada.length === 0) {
            listaContainer.innerHTML = `<div class="sem-agendamentos">🕊️ Nenhum agendamento encontrado. Agende agora! 🕊️</div>`;
            return;
        }
        let html = "";
        for (let ag of listaFiltrada) {
            const dataLegivel = formatarDataLegivel(ag.data);
            html += `
                <div class="card">
                    <div class="card-header">
                        <div class="nome-cliente">👁️ ${escapeHtml(ag.nome)}</div>
                        <div class="data-hora">📅 ${dataLegivel} • ⏰ ${ag.horario}</div>
                    </div>
                    <div class="servico">
                        <span>💎 ${escapeHtml(ag.servico)}</span>
                        <span>📞 ${escapeHtml(ag.telefone)}</span>
                    </div>
                    <div class="observacao">📌 ${escapeHtml(ag.obs || "Sem observações")}</div>
                    <div style="display: flex; justify-content: flex-end;">
                        <button class="btn-remover" data-id="${ag.id}">❌ Cancelar</button>
                    </div>
                </div>
            `;
        }
        listaContainer.innerHTML = html;
        document.querySelectorAll('.btn-remover').forEach(btn => {
            btn.addEventListener('click', (e) => {
                const id = Number(btn.getAttribute('data-id'));
                if (confirm("Remover este agendamento?")) {
                    agendamentos = agendamentos.filter(ag => ag.id !== id);
                    ordenarAgendamentos();
                    salvarAgendamentos();
                    renderizarAgendamentos();
                }
            });
        });
    }

    function adicionarAgendamento(event) {
        event.preventDefault();
        const nome = nomeInput.value.trim();
        const telefone = telefoneInput.value.trim();
        const data = dataInput.value;
        const horario = horarioSelect.value;
        const servico = servicoSelect.value;
        const obs = obsTextarea.value.trim();
        if (!nome || !telefone || !data || !horario || !servico) {
            alert("❌ Preencha todos os campos obrigatórios.");
            return;
        }
        const hoje = new Date();
        hoje.setHours(0,0,0,0);
        if (new Date(data) < hoje) {
            alert("⚠️ Não agende em datas passadas.");
            return;
        }
        if (agendamentos.some(ag => ag.data === data && ag.horario === horario)) {
            alert(`❗ Horário conflitante: ${formatarDataLegivel(data)} às ${horario} já ocupado.`);
            return;
        }
        const novoId = Date.now() + Math.floor(Math.random() * 10000);
        const novo = { id: novoId, nome, telefone, data, horario, servico, obs: obs || "Sem observações" };
        agendamentos.push(novo);
        ordenarAgendamentos();
        salvarAgendamentos();
        renderizarAgendamentos();
        form.reset();
        nomeInput.focus();
        alert("✅ Agendamento realizado!");
    }

    // BACKUP: exportar JSON
    function fazerBackup() {
        const dataStr = JSON.stringify(agendamentos, null, 2);
        const blob = new Blob([dataStr], { type: "application/json" });
        const url = URL.createObjectURL(blob);
        const a = document.createElement("a");
        const dataAtual = new Date().toISOString().slice(0,19).replace(/:/g, "-");
        a.download = `studio_emily_backup_${dataAtual}.json`;
        a.href = url;
        a.click();
        URL.revokeObjectURL(url);
        alert("✅ Backup gerado com sucesso!");
    }

    // Restaurar - selecionar arquivo
    btnSelecionarRestore.addEventListener("click", () => restoreFileInput.click());
    restoreFileInput.addEventListener("change", (e) => {
        if (restoreFileInput.files.length > 0) {
            arquivoSelecionado = restoreFileInput.files[0];
            infoRestoreMsg.innerText = `📁 Arquivo selecionado: ${arquivoSelecionado.name}`;
        } else {
            arquivoSelecionado = null;
            infoRestoreMsg.innerText = "Nenhum arquivo selecionado.";
        }
    });

    function restaurarBackup() {
        if (!arquivoSelecionado) {
            alert("❌ Nenhum arquivo selecionado. Clique em 'Selecionar arquivo' primeiro.");
            return;
        }
        const reader = new FileReader();
        reader.onload = function(evt) {
            try {
                const dadosImportados = JSON.parse(evt.target.result);
                if (!Array.isArray(dadosImportados)) throw new Error("Formato inválido: não é uma lista.");
                // validar estrutura básica
                const valido = dadosImportados.every(item => item.nome && item.data && item.horario && item.servico);
                if (!valido) throw new Error("Arquivo corrompido ou faltam campos essenciais.");
                if (confirm(`ATENÇÃO: Isso substituirá todos os ${agendamentos.length} agendamentos atuais por ${dadosImportados.length} novos registros. Deseja continuar?`)) {
                    agendamentos = dadosImportados.map((ag, idx) => {
                        if (!ag.id) ag.id = Date.now() + idx;
                        return ag;
                    });
                    ordenarAgendamentos();
                    salvarAgendamentos();
                    renderizarAgendamentos();
                    alert(`✅ Backup restaurado! ${agendamentos.length} agendamentos carregados.`);
                    arquivoSelecionado = null;
                    restoreFileInput.value = "";
                    infoRestoreMsg.innerText = "Nenhum arquivo selecionado.";
                }
            } catch(e) {
                alert("❌ Erro ao restaurar backup: " + e.message);
            }
        };
        reader.readAsText(arquivoSelecionado);
    }

    function limparTodosAgendamentos() {
        if (confirm("⚠️ ISSO APAGARÁ TODOS OS AGENDAMENTOS. Tem certeza? Faça backup antes.")) {
            if (confirm("Última confirmação: remover todos os agendamentos permanentemente?")) {
                agendamentos = [];
                salvarAgendamentos();
                renderizarAgendamentos();
                alert("🧹 Todos os agendamentos foram removidos.");
            }
        }
    }

    // Alternância de abas
    function ativarAba(abaId) {
        tabContents.agenda.classList.remove("active");
        tabContents.manutencao.classList.remove("active");
        tabContents[abaId].classList.add("active");
        tabBtns.forEach(btn => {
            if (btn.getAttribute("data-tab") === abaId) btn.classList.add("active");
            else btn.classList.remove("active");
        });
    }

    tabBtns.forEach(btn => {
        btn.addEventListener("click", () => {
            const tab = btn.getAttribute("data-tab");
            if (tab === "agenda") ativarAba("agenda");
            else if (tab === "manutencao") ativarAba("manutencao");
        });
    });

    // Data mínima
    function setMinDate() {
        const today = new Date();
        const yyyy = today.getFullYear();
        const mm = String(today.getMonth() + 1).padStart(2, '0');
        const dd = String(today.getDate()).padStart(2, '0');
        dataInput.setAttribute('min', `${yyyy}-${mm}-${dd}`);
    }

    // Eventos finais
    form.addEventListener("submit", adicionarAgendamento);
    btnBackup.addEventListener("click", fazerBackup);
    btnRestaurar.addEventListener("click", restaurarBackup);
    btnLimparTudo.addEventListener("click", limparTodosAgendamentos);
    filtroInput.addEventListener("input", () => renderizarAgendamentos());
    btnLimparFiltro.addEventListener("click", () => {
        filtroInput.value = "";
        renderizarAgendamentos();
    });

    window.addEventListener("DOMContentLoaded", () => {
        setMinDate();
        carregarAgendamentos();
    });
</script>
</body>
</html>